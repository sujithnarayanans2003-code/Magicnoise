{
  "name": "acoustic-ai",
  "version": "1.0.0",
  "description": "SonicMind AI — Acoustic Optimization Engine powered by Groq",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "node src/index.js",
    "dev:frontend": "vite --port 5000 --host 0.0.0.0",
    "build": "vite build",
    "start": "node src/index.js"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "express": "^4.22.2",
    "groq-sdk": "^0.3.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.7.0",
    "concurrently": "^9.2.1",
    "vite": "^5.4.21"
  }
}
